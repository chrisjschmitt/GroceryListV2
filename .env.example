# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/groceryscout

# Google Gemini (product matching, price audit)
GEMINI_API_KEY=

# Tampermonkey / ingestion API auth (generate a long random string)
GROCERY_SECRET_TOKEN=

# Optional: scraper price ingestion (Bearer token)
SCRAPER_API_KEY=

# Optional: admin/write API protection (future)
# ADMIN_API_KEY=

# Local dev
APP_URL=http://localhost:3000
NODE_ENV=development

# Optional: CORS allowlist (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3000,https://basketwise.ca
